{
  "name": "a11y-engineering-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "One-repo accessibility engineering toolkit",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run --config packages/audit-panel/vitest.config.js",
    "test:watch": "vitest --config packages/audit-panel/vitest.config.js",
    "build": "node packages/audit-panel/build.mjs",
    "build:all": "npm run build"
  },
  "devDependencies": {
    "vitest": "^3.1.1",
    "jsdom": "^26.0.0",
    "esbuild": "^0.25.0"
  },
  "license": "MIT"
}
